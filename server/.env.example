# Grimoire Pro — Environment Variables
# Copy to .env for local development: cp .env.example .env
# On Railway, set these in Dashboard → Variables

# ─── Server ───
PORT=3000
NODE_ENV=development

# ─── Anthropic ───
# Your managed API key — the one Pro users share via the proxy
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ─── PostgreSQL ───
# Railway provides this automatically when you attach Postgres
DATABASE_URL=postgresql://user:password@localhost:5432/grimoire

# ─── Auth ───
# Generate with: openssl rand -hex 32
JWT_SECRET=your-32-byte-hex-secret-here

# ─── Stripe ───
# From Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# From Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# From Stripe Dashboard → Products → Grimoire Pro → Price ID
STRIPE_PRICE_ID=price_...

# ─── Usage Limits (optional, defaults shown) ───
# SCAN_SOFT_CAP=50
# SCAN_HARD_CAP=100
# ANNOTATION_SOFT_CAP=100
# ANNOTATION_HARD_CAP=200

# ─── CORS (optional) ───
# ALLOWED_ORIGINS=https://grimoire.dev
